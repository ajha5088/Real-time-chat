NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_EXPIRES_IN=7d

POSTGRES_URL=postgresql://user:password@host:port/dbname
MONGODB_URI=mongodb://user:password@host:port/dbname
NEO4J_URI=neo4j+s://your-neo4j-instance
NEO4J_USERNAME=your_neo4j_user
NEO4J_PASSWORD=your_neo4j_password

REDIS_URL=redis://localhost:6379
MESSAGE_QUEUE_NAME=chat_message_index_queue
MESSAGE_QUEUE_TIMEOUT=0

# Set MILVUS_ADDRESS only if Milvus is available for semantic search
MILVUS_ADDRESS=localhost:19530
OPENAI_API_KEY=your_openai_api_key
